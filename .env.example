# Copy this file to .env for local development.
# Do not commit real API keys.

# Aliyun Bailian / DashScope OpenAI-compatible API.
# The current code reads DASHSCOPE_API_KEY first, then OPENAI_API_KEY.
DASHSCOPE_API_KEY=your_bailian_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Optional aliases if your local machine uses these names.
BAILIAN_API_KEY=your_bailian_api_key_here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus

# Keep false for deterministic local development unless you want real LLM calls.
LLM_ENABLED=false

# --- Trace / Eval persistence database ---
# Local Python process connects through 127.0.0.1 because MySQL is exposed by Docker.
# Docker Compose api service uses TRACE_DB_DOCKER_URL because "localhost" inside
# the container points to the api container itself.
TRACE_MYSQL_ROOT_PASSWORD=change_me_root_password
TRACE_MYSQL_DATABASE=customer_trace
TRACE_MYSQL_USER=customer
TRACE_MYSQL_PASSWORD=change_me_trace_password
TRACE_MYSQL_HOST_PORT=3307
TRACE_DB_URL=mysql+pymysql://customer:change_me_trace_password@127.0.0.1:3307/customer_trace
TRACE_DB_DOCKER_URL=mysql+pymysql://customer:change_me_trace_password@mysql:3306/customer_trace
TRACE_DB_POOL_SIZE=5
TRACE_DB_MAX_OVERFLOW=10

# RAG: directory of .txt / .md knowledge files (default: ./data/knowledge)
# KNOWLEDGE_DIR=data/knowledge

# --- Vector RAG (Phase 1, API embedding) ---
# keyword = 关键词检索；chroma = Chroma 向量检索（需先 POST /api/knowledge/reindex 或 rebuild_index）
RAG_BACKEND=chroma

CHROMA_PERSIST_DIR=data/chroma
EMBEDDING_MODEL=text-embedding-v4
# v4 支持多维度，常用 1024（默认）；与建索引、查询必须一致
EMBEDDING_DIMENSIONS=1024
RAG_TOP_K=3
# 向量相似度阈值（cosine 距离下需实测，先 0.45 再调）
RAG_SCORE_THRESHOLD=0.45

# 重建索引 / 查询向量化是否要调 API（测试可 false + mock）
EMBEDDING_ENABLED=true
