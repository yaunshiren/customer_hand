# Copy this file to .env for local development.
# Do not commit real API keys.

# Aliyun Bailian / DashScope OpenAI-compatible API.
# The current code reads DASHSCOPE_API_KEY first, then OPENAI_API_KEY.
DASHSCOPE_API_KEY=your_bailian_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Optional aliases if your local machine uses these names.
BAILIAN_API_KEY=your_bailian_api_key_here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus

# Keep false for deterministic local development unless you want real LLM calls.
LLM_ENABLED=false

# RAG: directory of .txt / .md knowledge files (default: ./data/knowledge)
# KNOWLEDGE_DIR=data/knowledge
